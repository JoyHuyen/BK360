    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^5.20.0",
    "argon2": "^0.41.1",
    "sharp": "^0.33.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.0.0",
