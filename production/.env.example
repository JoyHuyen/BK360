# ===== Copy thành .env và đổi các secret trước khi chạy production =====

# HTTP cổng Nginx expose ra ngoài (production: đặt 80, sau reverse-proxy TLS)
HTTP_PORT=8080

# PostgreSQL
POSTGRES_USER=bk360
POSTGRES_PASSWORD=change_me_db_pass
POSTGRES_DB=bk360
# DATABASE_URL dùng trong container api (host = tên service "postgres")
DATABASE_URL=postgresql://bk360:change_me_db_pass@postgres:5432/bk360?schema=public

# Redis
REDIS_URL=redis://redis:6379

# API
PORT=3000
# Project mặc định (multi-project — hiện chạy 1 project)
DEFAULT_PROJECT_SLUG=bk360
CORS_ORIGIN=http://localhost:8080
MEDIA_DIR=/data/media
PUBLIC_MEDIA_BASE=/media

# JWT — BẮT BUỘC đổi sang chuỗi ngẫu nhiên dài (vd: openssl rand -hex 32)
JWT_ACCESS_SECRET=change_me_access_secret_random_long
JWT_REFRESH_SECRET=change_me_refresh_secret_random_long
ACCESS_TTL=15m
REFRESH_TTL=7d
# Đặt true khi chạy sau HTTPS để cookie refresh chỉ gửi qua TLS
COOKIE_SECURE=false

# Tài khoản superadmin khởi tạo khi chạy seed
ADMIN_EMAIL=admin@bk360.local
ADMIN_PASSWORD=change_me_admin_pass
ADMIN_NAME=Quản trị viên
